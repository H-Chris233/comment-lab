{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Comment Lab",
  "version": "0.1.0",
  "identifier": "com.commentlab.desktop",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev:all",
    "beforeBuildCommand": "npm run desktop:prepare"
  },
  "app": {
    "windows": [
      {
        "title": "Comment Lab",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/comment-lab-python-sidecar",
      "binaries/comment-lab-node-server"
    ]
  }
}
