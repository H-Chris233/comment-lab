    "e2e:aliyun": "node scripts/e2e-aliyun-generate.mjs"
  },
  "dependencies": {
    "nuxt": "^3.20.0"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.12"
  }
}
