# DashScope / 阿里云百炼
ALIYUN_API_KEY=
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_MODEL=qwen3.5-omni-plus
# Python 侧车也兼容以下别名，通常无需同时配置：
# DASHSCOPE_API_KEY=
# ALIYUN_DASHSCOPE_API_KEY=
# DASHSCOPE_HTTP_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 抖音解析（TikHub）
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io

# 视频与生成限制
MAX_VIDEO_SIZE_MB=1000
MAX_COMPRESS_VIDEO_SIZE_MB=100
GENERATE_TIMEOUT_MS=3600000
TEMP_VIDEO_RETENTION_MINUTES=10
TEMP_VIDEO_DIR=.tmp/douyin-downloads

# 调试与认证
DEBUG_RAW_ENABLED=false
AUTH_LOCK_FILE=.tmp/auth-lock.json

# Python DashScope 侧车
PYTHON_DASHSCOPE_SERVICE_URL=http://127.0.0.1:8001

# Docker / 本机生产预览端口
APP_PORT=3000

# Docker Python 镜像构建索引（可按网络环境调整）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
